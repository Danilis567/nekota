rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
   match /posts/{postId} {
      // Herkes okuyabilir ve listeleyebilir.
      allow get, list: if true;

      // Sadece giriş yapmış kullanıcılar (admin) yeni yazı oluşturabilir ve silebilir.
      allow create, delete: if request.auth != null;

      // YENİ KURAL: Herkes, sadece 'viewCount' alanını güncelleyebilir.
      // Diğer alanları (title, content vb.) değiştiremez.
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']);

      // YENİ KURAL: Giriş yapmış bir kullanıcı (admin) ise tüm alanları güncelleyebilir.
      allow update: if request.auth != null;
    }
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
     match /{path=**}/comments/{commentId} {
      // Sadece giriş yapmış kullanıcılar (admin) tüm yorumları okuyabilir ve silebilir.
      allow read, delete: if request.auth != null;
    }
  }
}